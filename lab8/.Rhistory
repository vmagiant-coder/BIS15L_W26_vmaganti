#install.packages("naniar")
library("tidyverse")
library("naniar")
library("janitor")
life_history <- read_csv("data/mammal_lifehistories_v3.csv") %>% clean_names()
glimpse(life_history)
summary(life_history)
life_history %>%
summarize(across(everything(), ~ sum(is.na(.))))
life_history %>%
summarize(across(everything(), ~ sum(.==-999)))
life_history_no_nas <-
read_csv("data/mammal_lifehistories_v3.csv", na="-999") %>%
clean_names()
life_history_no_nas %>%
summarize(across(everything(), ~ sum(.==-999)))
summary(life_history_no_nas)
hist(life_history_no_nas$max_life)
life_history_no_nas %>%
filter(max_life==0) %>%
select(order, family, genus, species, max_life)
life_history_no_nas <- life_history %>%
mutate(max_life=na_if(max_life, 0))
life_history_no_nas
miss_var_summary(life_history_no_nas)
gg_miss_var(life_history_no_nas)
life_history_no_nas %>%
ggplot(aes(x=log10(mass), y= log10(wean_mass))) +
geom_point()+
geom_miss_point()
life_history_no_nas %>%
group_by(order) %>%
miss_var_summary(order = T)
life_history %>% #going back to the original data
replace_with_na(replace = list(newborn = "not measured",
weaning= -999,
wean_mass= -999,
afr= -999,
max_life= 0,
litter_size= -999,
gestation= -999,
mass= -999)) %>%
miss_var_summary()
life_history %>%
replace_with_na_all(condition = ~.x == -999) %>%
miss_var_summary()
common_na_strings
common_na_numbers
life_history %>%
replace_with_na_all(condition = ~.x %in% c(common_na_numbers, common_na_strings)) %>%
mutate(newborn=na_if(newborn, "not measured"))
cites <-
read_csv("data/cites.csv") %>%
clean_names()
summary(cites)
cites%>%
miss_var_summary()
cites %>%
group_by(class) %>%
select(class, exporter_reported_quantity) %>%
miss_var_summary() %>%
arrange(desc(n_miss))
library("tidyverse")
library("janitor")
library("lubridate") #this will help us manage dates
table_A <- read_csv("data/table_A.csv")
table_B <- read_csv("data/table_B.csv")
table_A
table_B
#join_type(firstTable, secondTable, by=columnTojoinOn)
inner_join(table_A, table_B, by="customer_ID")
left_join(table_A, table_B, by = "customer_ID")
right_join(table_A, table_B, by = "customer_ID")
full_join(table_A, table_B, by = "customer_ID")
anti_join(table_A, table_B, by="customer_ID") #use to troubleshoot problematic joins
today()
now()
dateformat1 <- "20200922"
dateformat2 <- "09-22-2020"
dateformat3 <- "22/09/2020"
dateformat4 <- "09-22-2020 17:00:00"
dateformat5 <- "20200922 170000"
ymd(dateformat1)
mdy(dateformat2)
dmy(dateformat3)
mdy_hms(dateformat4)
ymd_hms(dateformat5)
records <- read_csv("data/spider_records.csv") %>%
clean_names()
records
locations <- read_csv("data/spiders_locations.csv") %>%
clean_names()
locations
spiders_with_locs <- full_join(records, locations, by = "accession")
names(spiders_with_locs)
spiders_with_locs %>%
mutate(date = dmy(date))
write.csv(spiders_with_locs, file = "spiders_with_locs.csv", row.names = F)
library(tidyverse)
library(janitor)
#install.packages("ggmap")
library(ggmap)
#install.packages("leaflet")
library(leaflet)
register_stadiamaps("e90f7f28-b515-4bb7-a0e1-807ba10a7ee8", write = FALSE)
spiders <- read_csv("data/spiders_with_locs.csv")%>%
clean_names() %>%
filter(latitude<=42)
names(spiders)
spiders %>%
select(latitude, longitude) %>%
summary()
lat <- c(34.67, 41.80)
long <- c(124.1, -115.5)
bbox <- make_bbox(long, lat, f=0.03)
map1 <- get_stadiamap(bbox, maptype = "stamen_terrain", zoom = 7)
ggmap(map1)
ggmap(map1) +
geom_point(data=spiders, aes(longitude, latitude), size = 0.75, color = "black", alpha = 0.8) +
labs(x = "Longitude", y = "Latitude", title = "CA Usofila Records")
spiders %>%
summarize(
lon_min=min(longitude, na.rm = T),
lon_max=max(longitude, na.rm = T),
lat_min=min(latitude, na.rm = T),
lat_max=max(latitude, na.rm = T))
lon_min <- -124.13
lon_max <- -115.49
lat_min <- 34.67
lat_max <- 41.8
leaflet(spiders) %>%
addProviderTiles(providers$Stadia.StamenTerrain) %>%
addCircleMarkers(
lng = ~longitude,
lat = ~latitude,
radius = 2,
stroke = FALSE,
fillOpacity=0.7
) %>%
addScaleBar(position = "bottomleft") %>%
fitBounds(lng = lon_min, lat = lat_min,
lng2=lon_max, lat2 = lat_max)
leaflet(spiders) %>%
addTiles() %>%
addCircleMarkers(
lng = ~longitude,
lat = ~latitude,
radius = 2,
stroke = FALSE,
fillOpacity=0.7
) %>%
addScaleBar(position = "bottomleft") %>%
fitBounds(lng = lon_min, lat = lat_min,
lng2=lon_max, lat2 = lat_max)
grizzly <- read_csv("data/bear-sightings.csv") %>%
clean_names
grizzly %>%
select(latitude, longitude) %>%
summary()
bearslat <- c(55.02, 70.37)
bearslong <- c(-166.2, -131.3)
bbox <- make_bbox(long, lat, f=0.03)
bearmap <- get_stadiamap(bbox, maptype = "stamen_terrain", zoom = 5)
ggmap(bearmap)
ggmap(bearmap) +
geom_point(data = grizzly, aes(longitude, latitude), size = 0.8, color = "purple", alpha = 0.8) +
labs(x="Longitude", y = "Latitude", title = "Grizzly Bears in Alaska")
