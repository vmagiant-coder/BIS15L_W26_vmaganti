ui <- fluidPage(
selectInput("x",
"Select X Variable",
choices = c("bill_length_mm",
"bill_depth_mm",
"flipper_length_mm",
"body_mass_g"),
selected="bill_length_mm"),
selectInput("y",
"Select Y Variable",
choices = c("bill_length_mm",
"bill_depth_mm",
"flipper_length_mm",
"body_mass_g"),
selected="bill_length_mm"),
checkboxInput("show_lm",
"Show best-fit line (lm)",
value = FALSE),
plotOutput("plot",
width = "500px",
height = "400px")
)
server <- function(input, output, session) {
output$plot <- renderPlot({
ggplot(penguins,
aes(x = .data[[input$x]],
y = .data[[input$y]])) +
geom_point(na.rm = T) +
if(input$show_lm)
geom_smooth(method = "lm", se = F, na.rm = T)
else
NULL
})
}
shinyApp(ui, server)
ui <- fluidPage(
selectInput("x",
"Select X Variable",
