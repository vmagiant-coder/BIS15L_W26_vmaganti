size = 2,
alpha = 0.7) +
labs(title = "Polar Bear Locations by Population",
x = "Longitude",
y = "Latitude",
color = "Population") +
theme_minimal()
lat <- c(62.46, 72.70)
long <- c(-172.2, -134.8)
bbox <- make_bbox(long, lat, f = 0.03)
bears_map <- get_stadiamap(bbox, maptype = "stamen_terrain", zoom = 5)
ggmap(bears_map) +
geom_point(
data=polar_bears_no_nas,
aes(x = long, y = lat, color = popn),
size = 2,
alpha = 0.7) +
labs(title = "Polar Bear Locations by Population",
x = "Longitude",
y = "Latitude",
color = "Population") +
theme_minimal()
