server <- function(input, output, session) {
output$plot <- renderPlot({
ggplot(penguins,
aes(x = .data[[input$x]],
y = .data[[input$y]])) +
geom_point(na.rm = T) +
if(input$show_lm)
geom_smooth(method = "lm", se = F, na.rm = T)
else
NULL
})
}
shinyApp(ui, server)
