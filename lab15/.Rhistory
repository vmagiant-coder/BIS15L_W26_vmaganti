library(tidyverse)
library(janitor)
library(shiny)
library(shinydashboard)
elephants <- read_csv("data/elephants_data/elephants.csv") %>%
clean_names()
library(shiny)
ui <- dashboardPage(
dashboardHeader(title = "Elephant Age and Height by Sex"),
dashboardSidebar(
selectInput("x",
"Select Variable",
choices = c("age",
"height"),
selected =  "age")
),
dashboardBody(
plotOutput("plot", width = "600px", height = "500px")
)
)
server <- function(input, output, session) {
output$plot <- renderPlot({
elephants %>%
filter(sex != "NA") %>%
ggplot(aes(x=sex,
y=.data[[input$x]],
fill = sex)) +
geom_boxplot(alpha = 0.75) +
labs(title = "Range by Sex",
x = "Sex",
y = input$x) +
theme_minimal()
})
}
shinyApp(ui, server)
ui <- dashboardPage(
dashboardHeader(title = "Elephant Age and Height by Sex"),
dashboardSidebar(
selectInput("x",
"Select Variable",
choices = c("age",
"height"),
selected =  "age")
),
dashboardBody(
plotOutput("plot", width = "600px", height = "500px")
)
)
runApp('elephants.R')
library(shiny); runApp('msleep_app.r')
ui <- dashboardPage(
dashboardHeader(title = "Distribution of Gestation Length by Order"),
dashboardSidebar(
selectInput("x",
"Select Order",
choices = sort(unique(gestation$order)), #looks into order variable and pulls out all possible orders without typing them, and sort puts them in order
selected = "Afrosoricida"),
selectInput("y",
"Select Variable",
choices = c("bodymass",
"longevity",
"gestationlength"),
selected = "longevity")
),
dashboardBody(
plotOutput("plot", width = "600px", height = "500px")
)
)
library(tidyverse)
library(shiny)
library(shinydashboard)
library(janitor)
gestation <- read_csv("data/Data_S1.csv") %>%
clean_names() %>%
rename(gestationlength=gestationength)
names(gestation)
library(shiny)
ui <- fluidPage(
selectInput("x",
"Select Order",
choices = sort(unique(gestation$order)), #looks into order variable and pulls out all possible orders without typing them, and sort puts them in order
selected = "Afrosoricida"),
selectInput("y",
"Select Variable",
choices = c("bodymass",
"longevity",
"gestationlength"),
selected = "longevity"),
plotOutput("plot", width = "600px", height = "500px")
)
server <- function(input, output, session) {
output$plot <- renderPlot({
gestation %>%
filter(input$x == .data[["order"]]) %>%
ggplot(aes(.data[[input$y]])) +
geom_density(fill = "deeppink2",
color = "black",
alpha = 0.6) +
theme_minimal()
})
}
shinyApp(ui, server)
ui <-
dashboardPage(
dashboardHeader(title = "This is the Header"),
dashboardSidebar(title = "This is the Sidebar"),
dashboardBody() # this is where the output will go
)
server <- function(input, output) { }
shinyApp(ui, server)
