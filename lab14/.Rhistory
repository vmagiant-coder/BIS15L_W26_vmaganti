register_stadiamaps("e90f7f28-b515-4bb7-a0e1-807ba10a7ee8", write = FALSE)
sharks <- read_csv("data/SharkIncidents_1950_2022_220302.csv") %>%
clean_names() %>%
filter(longitude !="NA" & latitude !="NA") %>% # pulling out NA locations
mutate(longitude = as.numeric(longitude)) # converting longitude to numeric
sharks %>%
select(latitude, longitude) %>%
summary()
lat_range <- range(sharks$latitude)
long_range <- range(sharks$longitude)
bbox_sharks <- make_bbox(
lon = long_range,
lat = lat_range,
f= 0.03
)
bbox_sharks
ca_map <- get_stadiamap(
bbox = bbox_sharks,
maptype = "stamen_terrain",
zoom = 6
)
ggmap(ca_map)
ggmap(ca_map) +
geom_point(data = sharks,
aes(longitude, latitude),
color = "blue",
alpha = 0.6,
size = 1.5) +
labs(
title = "California Shark Attacks (1950-2022)",
x = "Longitude",
y = "Latitude"
)
fatalities <- sharks %>%
filter(str_detect(tolower(injury), "fatal"))
geom_point(data = fatalities,
aes(longitude, latitude),
color = "deeppink",
alpha = 0.8,
size = 2.5) +
labs(
title = "Fatal Shark Attacks in California from 1950 to 2022",
x = "Longitude",
y = "Latitude"
)
fatalities <- sharks %>%
filter(str_detect(tolower(injury), "fatal"))
ggmap(ca_map) +
geom_point(data = fatalities,
aes(longitude, latitude),
color = "deeppink",
alpha = 0.8,
size = 2.5) +
labs(
title = "Fatal Shark Attacks in California from 1950 to 2022",
x = "Longitude",
y = "Latitude"
)
bounds <- sharks %>%
summarize(
lon_min = min(longitude, na.rm = T),
lon_max = max(longitude, na.rm = T),
lat_min = min(latitude, na.rm = T),
lat_max = max(latitude, na.rm = T)
)
leaflet(fatalities) %>%
addProviderTiles(providers$Stadia.StamenTerrain) %>%
addCircleMarkers(
lng = ~longitude,
lat = ~latitude,
radius = 5,
color = "red",
stroke = FALSE,
fillOpacity = 0.8
) %>%
addScaleBar(position = "bottomleft") %>%
fitBounds(
lng = bounds$lon_min,
lat = bounds$lat_min,
lng2 = bounds$lon_max,
lat2 = bounds$lat_max
)
county_counts <- sharks %>%
count(county, sort = T)
county_counts
top_county <- county_counts %>%
slice(1)
top_county
ggmap(ca_map) +
geom_point(data = top_county_data,
aes(longitude, latitude),
color = "purple",
alpha = 0.8,
size = 2) +
labs(
title = "Number of Shark Attacks in the Top County",
x = "Longitude",
y = "Latitude"
)
top_county_data <- sharks %>%
filter(county == top_county$county) %>%
distinct(longitude, latitude, .keep_all = T)
ggmap(ca_map) +
geom_point(data = top_county_data,
aes(longitude, latitude),
color = "purple",
alpha = 0.8,
size = 2) +
labs(
title = "Number of Shark Attacks in the Top County",
x = "Longitude",
y = "Latitude"
)
